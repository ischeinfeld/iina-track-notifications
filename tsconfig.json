{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020", "DOM"],
    "types": ["iina-plugin-definition", "node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
