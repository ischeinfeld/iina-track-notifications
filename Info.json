{
  "name": "Track Change Notifications",
  "identifier": "io.github.ischeinfeld.iina-track-notifications",
  "version": "0.1.1",
  "description": "Send configurable macOS notifications when the current playlist item changes.",
  "author": {
    "name": "Isaac Scheinfeld",
    "url": "https://github.com/ischeinfeld"
  },
  "entry": "dist/main.js",
  "preferencesPage": "pref.html",
  "permissions": [
    "file-system"
  ],
  "ghRepo": "ischeinfeld/iina-track-notifications",
  "ghVersion": 2,
  "preferenceDefaults": {
    "enabled": true,
    "notificationMode": "both",
    "onlyMainWindow": true,
    "notifyOnInitialTrack": true,
    "notifyOnEndWithoutNext": false,
    "notifyOnSameTrackRestart": false,
    "titleDelayMs": 300,
    "dedupeMs": 1000,
    "soundName": ""
  }
}
