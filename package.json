{
  "name": "iina-track-notifications",
  "version": "0.1.0",
  "description": "Send configurable macOS notifications when the current IINA playlist item changes.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ischeinfeld/iina-track-notifications.git"
  },
  "bugs": {
    "url": "https://github.com/ischeinfeld/iina-track-notifications/issues"
  },
  "homepage": "https://github.com/ischeinfeld/iina-track-notifications#readme",
  "scripts": {
    "build": "npm run build:ts && npm run build:plugin",
    "build:ts": "tsc -p tsconfig.json",
    "build:plugin": "node scripts/build-plugin.cjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "link": "\"/Applications/IINA.app/Contents/MacOS/iina-plugin\" link .",
    "unlink": "\"/Applications/IINA.app/Contents/MacOS/iina-plugin\" unlink .",
    "pack": "\"/Applications/IINA.app/Contents/MacOS/iina-plugin\" pack ."
  },
  "devDependencies": {
    "esbuild": "^0.25.3",
    "iina-plugin-definition": "^0.99.3",
    "typescript": "^6.0.2"
  }
}
